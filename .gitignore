*.log
.DS_Store
tmpclaude-*

# Arquivos de ambiente (NUNCA commitar!)
.env
.env.backup
.env.production
.env.local
.env.*.local

# Manter apenas os templates
!.env.example
!.env.local.example
!.env.production.example

.phpactor.json
.phpunit.result.cache
/.fleet
/.idea
/.nova
/.phpunit.cache
/.vscode
/.zed
/auth.json
/node_modules
/public/build
/public/hot
/public/storage
# Build artifacts copiados pra raíz public/ (Vite gera em frontend/dist;
# o que está em /public/* na VPS é overflow de tentativas antigas — não
# é servido pelo nginx atual mas também não atrapalha)
/public/assets
/public/index.html
/public/omnify-favicon.svg
/public/vite.svg
/storage/*.key
/storage/pail
/vendor
Homestead.json
Homestead.yaml
Thumbs.db
__pycache__/
*.pyc

.cursor/mcp.json

# Claude Code state local
.claude/scheduled_tasks.lock
.playwright-mcp/

# Scripts ad-hoc com credenciais ou tokens (NUNCA commitar)
.ssh_*.py
*_temp.php
check_*_temp.*

# Screenshots de debug
review-*.png

# Certificados SSL — gerados pelo certbot (ou montados via volume) por ambiente.
# Cada VPS tem o próprio cert renovado periodicamente; commitar deixaria o repo
# dirty toda renovação e arrastaria certs antigos pra novos ambientes.
docker/nginx/ssl/*.pem
!docker/nginx/ssl/.gitkeep
